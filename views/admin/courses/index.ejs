<%- include('../../partials/header'); %>

<div class="app-shell course-builder-shell">
  <% if (user) { %>
    <%- include('../../partials/sidebar'); %>
  <% } %>

  <div class="app-main">
    <%- include('../../partials/navbar'); %>

    <main class="app-content course-workspace">
      <div class="course-page-head">
        <div>
          <p class="builder-eyebrow">Table courses</p>
          <h1>Courses</h1>
        </div>
        <a class="btn btn-dark" href="/teacher/courses/new">New course</a>
      </div>

      <section class="builder-panel">
        <form class="course-filter-bar" method="GET" action="/teacher/courses">
          <div class="filter-search">
            <label class="form-label" for="course-filter">Filter course</label>
            <input
              id="course-filter"
              class="form-control"
              type="search"
              name="q"
              value="<%= filters.q || '' %>"
              placeholder="Search by title or description"
            >
          </div>

          <div>
            <label class="form-label" for="status-filter">Status</label>
            <select id="status-filter" class="form-select" name="status">
              <option value="">All status</option>
              <% statusOptions.forEach((status) => { %>
                <option value="<%= status %>" <%= filters.status === status ? 'selected' : '' %>>
                  <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                </option>
              <% }) %>
            </select>
          </div>

          <button class="btn btn-outline-dark" type="submit">Filter</button>
        </form>

        <div class="table-responsive">
          <table class="table course-table align-middle">
            <thead>
              <tr>
                <th>Title</th>
                <th>Price</th>
                <th>Status</th>
                <th>Workload</th>
                <th>Chapters</th>
                <th>Description</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (courses.length === 0) { %>
                <tr>
                  <td colspan="7">
                    <div class="empty-state">
                      <strong>No courses found.</strong>
                      <span>Create a new course or change the filters.</span>
                    </div>
                  </td>
                </tr>
              <% } %>

              <% courses.forEach((course) => { %>
                <tr>
                  <td>
                    <div class="course-title-cell">
                      <% if (course.image) { %>
                        <img src="<%= course.image %>" alt="" class="course-thumb">
                      <% } else { %>
                        <span class="course-thumb course-thumb-empty"></span>
                      <% } %>
                      <div>
                        <a href="/teacher/courses/<%= course.id %>/edit" class="course-title-link">
                          <%= course.title %>
                        </a>
                        <small>ID <%= course.id %></small>
                      </div>
                    </div>
                  </td>
                  <td>$<%= Number(course.price || 0).toFixed(2) %></td>
                  <td>
                    <span class="status-pill status-<%= course.status %>">
                      <%= course.status.charAt(0).toUpperCase() + course.status.slice(1) %>
                    </span>
                  </td>
                  <td><%= course.workload_hours || 0 %> h</td>
                  <td><%= course.chapters_count %></td>
                  <td class="description-cell"><%= course.description_text || 'No description' %></td>
                  <td class="text-end">
                    <a class="btn btn-sm btn-outline-dark" href="/teacher/courses/<%= course.id %>/edit">Edit</a>
                    <form
                      method="POST"
                      action="/courses/delete"
                      class="d-inline"
                      onsubmit="confirmDelete(event, this)"
                    >
                      <input type="hidden" name="id" value="<%= course.id %>">
                      <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                    </form>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </div>
</div>

<%- include('../../partials/footer'); %>

<script>
  function confirmDelete(event, form) {
    event.preventDefault();
    if (confirm("Do you want to delete this course?")) {
      form.submit();
    }
  }
</script>
