<%- include('../../partials/header'); %>
<%- include('../../partials/navbar'); %>
<div class="container">
    <hr>
    <h2>Courses</h2>
    <hr>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Title</th>
                <th>Description</th>
                <th>Price</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% courses.forEach((course) => {%>
                <tr>
                    <td><%= course.id %></td>
                    <td><%= course.title %></td>
                    <td><%= course.description %></td>
                    <td><%= course.price %></td>
                    <td><%= course.status ? "Active" : "Inactive" %></td>
                    <td>
                        <form //add style = "display: inline;">
                            <button class="btn btn-warning">Edit</button>
                        </form>
                        <form method="post" action="/courses/delete" style="display: inline;" onsubmit="confirmDelete(event, this)"> 
                            <input type="hidden" name="id" value="<%= course.id %>">
                             <button class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a class="btn btn-success" href="/admin/courses/new">Create new course</a>
</div>
<%- include('../../partials/footer'); %>

<script>
    function confirmDelete(event, form){
        event.preventDefault();
        var decision = confirm("Do you want to delete this course?")
        if (decision) {
            form.submit();
        }
    }
</script>