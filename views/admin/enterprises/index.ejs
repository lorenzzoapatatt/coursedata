<%- include('../../partials/header'); %>
<%- include('../../partials/navbar'); %>

<div class="container">
    <hr>
    <h2>Enterprises</h2>
    <hr>
    <table class="table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>CNPJ</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% enterprises.forEach((enterprise) => { %>
                <tr>
                    <td><%= enterprise.id %></td>
                    <td><%= enterprise.name %></td>
                    <td><%= enterprise.cnpj %></td>
                    <td><%= enterprise.email %></td>
                    <td><%= enterprise.phone %></td>
                    <td><%= enterprise.is_active ? 'Active' : 'Inactive' %></td>
                    <td>
                        <a class="btn btn-primary" href="/admin/enterprises/edit/<%= enterprise.id %>">Edit</a>
                        <form method="post" action="/admin/enterprises/delete" style="display:inline;" onsubmit="confirmDelete(event, this)">
                            <input type="hidden" name="id" value="<%= enterprise.id %>">
                            <button type="submit" class="btn btn-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>
    <a class="btn btn-success" href="/admin/enterprises/new">Create Enterprise</a>
</div>

<%- include('../../partials/footer'); %>

<script>
    function confirmDelete(event, form) {
        event.preventDefault();
        if (confirm('Do you want to delete this enterprise?')) {
            form.submit();
        }
    }
</script>
