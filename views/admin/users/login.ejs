<%- include('../../partials/header'); %>
<%- include('../../partials/navbar'); %>

<div class="container">
    <hr>
    <div class="card mt-4">
        <div class="card-header">
            <h2>Login admin</h2>
        </div>
        <div class="card-body">
            <form action="/admin/auth" method="post">
                <input name="email" type="email" class="form-control mb-3" placeholder="Email" required>
                <input name="password" type="password" class="form-control mb-3" placeholder="Senha" required>
                
                <button type="submit" class="btn btn-primary">Entrar como admin</button>
            </form>
        </div>
    </div>
</div>

<%- include('../../partials/footer'); %>
