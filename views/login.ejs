<%- include('partials/header') %>

<div class="container">
  <div class="row justify-content-center mt-5">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header bg-primary text-white">
          <h4 class="card-title mb-0">
            <%= accountTypeName ? "Login de " + accountTypeName : "Login" %>
          </h4>
        </div>
        <div class="card-body">
          <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
              <%= error %>
              <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
          <% } %>

          <form action="/auth/login" method="POST">
            <% if (typeof accountTypeValue !== 'undefined') { %>
              <input type="hidden" name="accountType" value="<%= accountTypeValue %>">
            <% } %>

            <div class="mb-3">
              <label for="email" class="form-label">Email</label>
              <input
                type="email"
                class="form-control"
                id="email"
                name="email"
                required
                placeholder="seu@email.com"
              >
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Senha</label>
              <input
                type="password"
                class="form-control"
                id="password"
                name="password"
                required
                placeholder="Sua senha"
              >
            </div>

            <button type="submit" class="btn btn-primary w-100">
              Entrar
            </button>
          </form>

          <% if (typeof returnPath !== 'undefined') { %>
            <div class="text-center mt-3">
              <a href="<%= returnPath %>" class="text-decoration-none">Voltar para seleção de contas</a>
            </div>
          <% } %>

          <hr>

          <p class="text-center text-muted mb-0">
            Não tem conta?
            <a href="/register" class="text-decoration-none">Clique aqui para se registrar</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
