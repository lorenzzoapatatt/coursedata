<%- include('partials/header') %>

<div class="container">
  <div class="row justify-content-center mt-5">
    <div class="col-md-6">
      <div class="card">
        <div class="card-header bg-warning text-dark">
          <h4 class="card-title mb-0">Registrar Empresa</h4>
        </div>
        <div class="card-body">
          <p class="text-muted">A conta de empresa registra a própria organização. Não há seleção de outra empresa.</p>

          <form action="/enterprise/register" method="POST">
            <div class="mb-3">
              <label for="name" class="form-label">Nome da Empresa *</label>
              <input type="text" class="form-control" id="name" name="name" required placeholder="Nome da sua empresa">
            </div>

            <div class="mb-3">
              <label for="cnpj" class="form-label">CNPJ *</label>
              <input type="text" class="form-control" id="cnpj" name="cnpj" required placeholder="00.000.000/0000-00">
            </div>

            <div class="mb-3">
              <label for="email" class="form-label">Email *</label>
              <input type="email" class="form-control" id="email" name="email" required placeholder="contato@empresa.com">
            </div>

            <div class="mb-3">
              <label for="password" class="form-label">Senha *</label>
              <input type="password" class="form-control" id="password" name="password" required placeholder="Escolha uma senha segura">
            </div>

            <div class="mb-3">
              <label for="phone" class="form-label">Telefone</label>
              <input type="tel" class="form-control" id="phone" name="phone" placeholder="(11) 99999-9999">
            </div>

            <button type="submit" class="btn btn-warning w-100">Registrar Empresa</button>
          </form>

          <hr>

          <p class="text-center text-muted mb-0">
            Já possui conta?
            <a href="/enterprise/login" class="text-decoration-none">Faça login como empresa</a>
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
