<%- include('partials/header') %>

<div class="container">
  <div class="row justify-content-center mt-5">
    <div class="col-md-6">
      <div class="card border-danger">
        <div class="card-header bg-danger text-white">
          <h4 class="card-title mb-0">Erro de Acesso</h4>
        </div>
        <div class="card-body">
          <p class="card-text text-danger">
            <strong><%= message %></strong>
          </p>
          <p class="text-muted">
            Você não tem permissão para acessar este recurso. Se achar que isso é um erro, entre em contato com o administrador.
          </p>
          <a href="/" class="btn btn-primary">
            Voltar para Home
          </a>
          <a href="/logout" class="btn btn-secondary">
            Fazer Logout
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
