<%- include('../partials/header'); %>

<div class="public-course-shell">
  <%- include('../partials/navbar'); %>

  <main class="container app-content">
    <% const resources = course.attachment_resources || []; %>

    <section class="public-course-hero">
      <div class="public-course-intro">
        <p class="builder-eyebrow">Course</p>
        <h1><%= course.title %></h1>
        <div class="public-course-meta">
          <span class="status-pill status-<%= course.status %>">
            <%= course.status.charAt(0).toUpperCase() + course.status.slice(1) %>
          </span>
          <span class="status-pill"><%= course.workload_hours || 0 %> h</span>
          <span class="status-pill">$<%= Number(course.price || 0).toFixed(2) %></span>
        </div>
        <% if (course.status !== 'published' && canPreviewDraft) { %>
          <p class="text-muted mb-0">Previewing this draft course as a course manager.</p>
        <% } %>
      </div>

      <div class="public-course-media">
        <% if (course.image) { %>
          <img src="<%= course.image %>" alt="<%= course.title %> course image">
        <% } else { %>
          <span>No course image</span>
        <% } %>
      </div>
    </section>

    <div class="public-course-layout">
      <div>
        <section class="public-course-section">
          <h2>About this course</h2>
          <div class="course-description">
            <%- course.description || '<p>No description yet.</p>' %>
          </div>
        </section>

        <section class="public-course-section">
          <h2>Chapters</h2>
          <div class="public-chapter-list">
            <% if (chapters.length === 0) { %>
              <div class="empty-state">
                <strong>No chapters available yet.</strong>
                <span>Published chapters will appear here.</span>
              </div>
            <% } %>

            <% chapters.forEach((chapter, index) => { %>
              <article class="public-chapter-row">
                <span class="public-chapter-number"><%= index + 1 %></span>
                <div>
                  <h3><%= chapter.title %></h3>
                  <% if (chapter.description) { %>
                    <div class="course-description">
                      <%- chapter.description %>
                    </div>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      </div>

      <aside class="public-course-section">
        <h2>Resources</h2>
        <div class="attachment-list">
          <% if (resources.length === 0) { %>
            <div class="empty-state">
              <strong>No resources yet.</strong>
              <span>Course files and links will appear here.</span>
            </div>
          <% } %>

          <% resources.forEach((resource) => { %>
            <% const isFile = resource.type === 'file'; %>
            <% const isNote = resource.type === 'note'; %>
            <article class="attachment-row">
              <span class="attachment-icon attachment-icon-<%= resource.type %>">
                <%= isFile ? 'F' : isNote ? 'R' : 'L' %>
              </span>
              <div class="attachment-row-main">
                <% if (isFile) { %>
                  <a href="<%= resource.url %>" download="<%= resource.fileName || resource.title %>">
                    <%= resource.title %>
                  </a>
                <% } else if (resource.url) { %>
                  <a href="<%= resource.url %>" target="_blank" rel="noopener">
                    <%= resource.title %>
                  </a>
                <% } else { %>
                  <span><%= resource.title %></span>
                <% } %>
                <% if (resource.meta || resource.text) { %>
                  <small><%= resource.meta || resource.text %></small>
                <% } %>
              </div>
            </article>
          <% }) %>
        </div>
      </aside>
    </div>
  </main>
</div>

<%- include('../partials/footer'); %>
