<%- include('partials/header'); %>
<%- include('partials/navbar'); %>

<main class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-body p-4">
                    <div class="d-flex flex-column flex-md-row align-items-md-center gap-4">
                        <img src="<%= profilePhoto %>" alt="Profile photo" class="profile-info-photo">
                        <div class="flex-grow-1">
                            <h1 class="h3 mb-1"><%= account.name %></h1>
                            <p class="text-muted mb-3"><%= account.email %></p>
                            <dl class="row mb-0">
                                <dt class="col-sm-3">Phone</dt>
                                <dd class="col-sm-9"><%= account.phone %></dd>

                                <dt class="col-sm-3">Profile</dt>
                                <dd class="col-sm-9 text-capitalize"><%= profileName %></dd>
                            </dl>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <a href="/profile/edit" class="btn btn-primary">Edit</a>
                        <a href="/" class="btn btn-outline-secondary">Home</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('partials/footer'); %>
