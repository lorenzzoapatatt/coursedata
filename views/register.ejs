<%- include('partials/header'); %>
<%- include('partials/navbar'); %>

<div class="container">
    <hr>
    <h2>Escolha seu tipo de cadastro</h2>
    <p class="text-muted">Cada tipo de conta tem um formulario proprio.</p>

    <div class="row g-3 mt-2">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Aluno</h5>
                    <p class="card-text">Acesse o painel de usuario e acompanhe sua conta.</p>
                    <a href="/student/register" class="btn btn-primary">Cadastrar aluno</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Professor</h5>
                    <p class="card-text">Acesse o painel de cursos para gerenciar conteudo.</p>
                    <a href="/professor/register" class="btn btn-primary">Cadastrar professor</a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">Empresa</h5>
                    <p class="card-text">Cadastre os dados da empresa, incluindo CNPJ.</p>
                    <a href="/enterprise/register" class="btn btn-primary">Cadastrar empresa</a>
                </div>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer'); %>
