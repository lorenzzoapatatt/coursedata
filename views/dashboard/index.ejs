<%- include('../partials/header'); %>

<main class="dashboard-page">
  <% const profilePhoto = user?.profile_photo || '/images/user-profile-photo.svg'; %>
  <% const hasFilters = Boolean(filters.q); %>

  <header class="dashboard-topbar">
    <form class="dashboard-search" method="GET" action="/dashboard">
      <span class="dashboard-search-icon" aria-hidden="true"></span>
      <input
        type="search"
        name="q"
        value="<%= filters.q || '' %>"
        placeholder="Search for a course"
        aria-label="Search for a course"
      >
    </form>

    <div class="dashboard-user-actions">
      <% if (canManageCourses) { %>
        <a class="teacher-mode-link" href="/teacher/courses">Teacher mode</a>
      <% } %>
      <a class="dashboard-avatar" href="/profile/info" aria-label="Open profile">
        <img src="<%= profilePhoto %>" alt="">
      </a>
    </div>
  </header>

  <section class="dashboard-summary">
    <div>
      <p class="builder-eyebrow">Dashboard</p>
      <h1>Courses</h1>
      <p class="text-muted mb-0">
        <%= totalCourses %> courses available<% if (totalChapters) { %> with <%= totalChapters %> chapters<% } %>.
      </p>
    </div>
  </section>

  <% if (courses.length === 0) { %>
    <section class="dashboard-empty-state">
      <strong>No courses found.</strong>
      <span>
        <% if (hasFilters) { %>
          Try another search.
        <% } else { %>
          Courses from your company will appear here when they are available.
        <% } %>
      </span>
    </section>
  <% } %>

  <section class="dashboard-course-grid" aria-label="Course list">
    <% courses.forEach((course) => { %>
      <a class="dashboard-course-card" href="/courses/<%= course.id %>">
        <div class="dashboard-course-media">
          <% if (course.image) { %>
            <img src="<%= course.image %>" alt="<%= course.title %>">
          <% } else { %>
            <span><%= course.title.charAt(0).toUpperCase() %></span>
          <% } %>
        </div>
        <div class="dashboard-course-body">
          <h2><%= course.title %></h2>
          <p><%= course.category %></p>
          <div class="dashboard-course-meta">
            <span class="chapter-count-icon">[]</span>
            <span>
              <%= course.chapters_count %>
              <%= Number(course.chapters_count) === 1 ? 'Chapter' : 'Chapters' %>
            </span>
          </div>
          <strong>
            <% if (Number(course.price || 0) > 0) { %>
              $<%= Number(course.price || 0).toFixed(2) %>
            <% } else { %>
              Free
            <% } %>
          </strong>
        </div>
      </a>
    <% }) %>
  </section>
</main>

<%- include('../partials/footer'); %>
