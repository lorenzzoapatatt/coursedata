<nav class="navbar navbar-expand-lg bg-white border-bottom py-3 mb-4">
  <div class="container">
    <a href="/" class="navbar-brand d-flex align-items-center text-dark text-decoration-none">
        <!-- logo will go here -->
          <%- include('../components/logo') %>
      <svg class="bi me-2" width="40" height="32">
        <use xlink:href="#bootstrap"></use>
      </svg>
    </a>

    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
      aria-controls="navbarNav"
      aria-expanded="false"
      aria-label="Toggle navigation"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav ms-auto nav-pills">
        <li class="nav-item">
          <a href="/" class="nav-link active" aria-current="page">Home</a>
        </li>
        <% if (user) { %>
          <% (navLinks || []).forEach((link) => { %>
            <li class="nav-item">
              <a href="<%= link.href %>" class="nav-link"><%= link.label %></a>
            </li>
          <% }) %>
          <% const profilePhoto = user.profile_photo || "/images/user-profile-photo.svg"; %>
          <li class="nav-item dropdown ms-lg-2">
            <button
              class="btn dropdown-toggle profile-menu-toggle d-flex align-items-center p-0"
              type="button"
              data-bs-toggle="dropdown"
              aria-expanded="false"
            >
              <img
                src="<%= profilePhoto %>"
                alt="Profile photo"
                class="navbar-profile-photo"
              >
              <span class="visually-hidden">Profile menu</span>
            </button>
            <ul class="dropdown-menu dropdown-menu-end profile-dropdown-menu">
              <li class="px-3 py-2">
                <div class="d-flex align-items-center gap-3">
                  <img
                    src="<%= profilePhoto %>"
                    alt="Profile photo"
                    class="navbar-profile-photo profile-dropdown-photo"
                  >
                  <div class="text-truncate">
                    <div class="fw-semibold text-truncate"><%= user.name %></div>
                    <small class="text-muted text-truncate d-block"><%= user.email %></small>
                  </div>
                </div>
              </li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/profile/info">Info</a></li>
              <li><a class="dropdown-item" href="/profile/edit">Edit</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/logout">Logout</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item">
            <a href="/login" class="nav-link">Login</a>
          </li>
          <li class="nav-item">
            <a href="/register" class="nav-link">Register</a>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
